# gpm: quick add-commit-push (safer version)
# Requires a commit message. Uses current branch, not hardcoded main.
gpm() {
    if [ -z "$1" ]; then
        echo "Usage: gpm \"commit message\""
        return 1
    fi
    git add -A && git commit -m "$1" && git push
}

# obs-daily: create (if needed) and open a daily note (default: today)
# Usage: obs-daily [YYYY-MM-DD]
obs-daily() {
    if [ -z "$LIFE_VAULT" ]; then
        echo "LIFE_VAULT is not set"
        return 1
    fi
    local day=${1:-$(date +%Y-%m-%d)}
    local year=${day%%-*}
    local month=${day#*-}; month=${month%%-*}
    local weekday=$(date -j -f %Y-%m-%d "$day" +%A 2>/dev/null \
                 || date -d "$day" +%A)
    local dir="$LIFE_VAULT/Days/$year/$month"
    local file="$dir/$day.md"

    mkdir -p "$dir"
    if [ ! -f "$file" ]; then
        cat > "$file" <<EOF
#days
$weekday
Morning:

Afternoon:

Evening:

EOF
        echo "Created $file"
    fi
    ${EDITOR:-vim} "$file"
}

# og: ripgrep across vault markdown files
og() {
    if [ -z "$1" ]; then
        echo "Usage: og <pattern> [lab|life]"
        return 1
    fi
    local vault_path
    case "${2:-lab}" in
        lab)  vault_path="$LAB_VAULT" ;;
        life) vault_path="$LIFE_VAULT" ;;
        *)    vault_path="$2" ;;
    esac
    if [ -z "$vault_path" ]; then
        echo "Vault path not set. Check ~/.dotfiles.local"
        return 1
    fi
    rg --type md "$1" "$vault_path"
}

# remarimo: persistent remote marimo sessions via tmux + SSH port forwarding
# Each project gets its own tmux session (marimo-<name>) and port (8080+i)
# Usage: remarimo <hostname> [project]
remarimo() {
    local host="${1:?Usage: remarimo <hostname> [project]}"
    local project="${2:-home}"

    # Validate: allow path chars [a-zA-Z0-9_/.-]
    if [[ "$project" =~ [^a-zA-Z0-9_./-] ]]; then
        echo "remarimo: project path must contain only [a-zA-Z0-9_/.-]" >&2
        return 1
    fi

    # Sanitize for tmux session name (no . or / allowed)
    local wname="${project//[\/.]/-}"
    local session="marimo-${wname}"
    local dir="${2:+\$HOME/${2}}"
    dir="${dir:-\$HOME}"

    # Step 1: Quick SSH to determine port
    #   Existing session → read stored PORT env var
    #   New session → 8080 + number of existing marimo-* sessions
    local port
    port=$(ssh "${host}" \
        "export PATH=\$HOME/.local/bin:\$PATH; \
         if tmux has-session -t '${session}' 2>/dev/null; then \
             tmux show-environment -t '${session}' 2>/dev/null | grep '^PORT=' | cut -d= -f2; \
         else \
             count=\$(tmux list-sessions -F '#{session_name}' 2>/dev/null | grep -c '^marimo-'); \
             echo \$(( 8080 + \${count:-0} )); \
         fi")

    # Validate result is a port number
    if ! [[ "$port" =~ ^[0-9]+$ ]]; then
        echo "remarimo: failed to determine port (got: '${port}')" >&2
        return 1
    fi

    # Check local port is free
    if lsof -ti:"${port}" >/dev/null 2>&1; then
        echo "remarimo: local port ${port} already in use" >&2
        return 1
    fi

    # Step 2: SSH with port forwarding, create or attach to session
    local mcmd="export PATH=\$HOME/.local/bin:\$PATH; cd ${dir} && lsof -ti:${port} | xargs -r kill 2>/dev/null; uv run marimo edit notebook.py --watch --no-token --port ${port}"
    local ccmd="export PATH=\$HOME/.local/bin:\$PATH; cd ${dir} && claude --dangerously-skip-permissions"

    ssh -L "${port}:localhost:${port}" "${host}" -t \
        "export PATH=\$HOME/.local/bin:\$PATH; \
         if tmux has-session -t '${session}' 2>/dev/null; then \
             tmux attach -t '${session}'; \
         else \
             tmux new-session -d -s '${session}' -n marimo; \
             tmux set-environment -t '${session}' PORT '${port}'; \
             tmux source-file ~/.config/tmux/tmux.conf 2>/dev/null; \
             tmux send-keys -t '${session}':marimo '${mcmd}' Enter; \
             tmux split-window -t '${session}':marimo -v; \
             tmux send-keys -t '${session}':marimo '${ccmd}' Enter; \
             tmux select-pane -t '${session}':marimo.0; \
             tmux attach -t '${session}'; \
         fi"
}

# bwunlock: unlock Bitwarden vault for current shell session
bwunlock() {
    export BW_SESSION=$(bw unlock --raw)
}

# bwlock: lock vault and clear session
bwlock() {
    bw lock
    unset BW_SESSION
}

# mc: copy stdin to local clipboard via OSC 52 (works over SSH + tmux)
mc() {
    local input
    input=$(cat)
    if [ -n "$TMUX" ]; then
        printf '\ePtmux;\e\e]52;c;%s\a\e\\' "$(printf '%s' "$input" | base64 | tr -d '\n')"
    else
        printf '\e]52;c;%s\a' "$(printf '%s' "$input" | base64 | tr -d '\n')"
    fi
}

# changetheme: switch Ghostty theme + write state for nvim (macOS only)
if [ "$(uname)" = "Darwin" ]; then
    changetheme() {
        local CONFIG_PATH="$HOME/.config/ghostty/config"
        local STATE_FILE="$HOME/.local/state/theme"
        local fg bg theme desc

        case "$1" in
            d) fg="ffffff"; bg="000000"; theme="dark";  desc="dark (white on black)" ;;
            m) fg="cdd6f4"; bg="1e1e2e"; theme="dark";  desc="mocha (catppuccin)" ;;
            w) fg="000000"; bg="ffffff"; theme="light"; desc="light (black on white)" ;;
            c) fg="000000"; bg="F0EEE4"; theme="cream"; desc="cream (black on cream)" ;;
            *)
                echo "Usage: changetheme [d|m|w|c]"
                echo "  d - dark    m - mocha    w - light    c - cream"
                return ;;
        esac

        local temp_file=$(mktemp)
        while IFS= read -r line; do
            if [[ $line == "foreground ="* ]]; then
                echo "foreground = #$fg"
            elif [[ $line == "background ="* ]]; then
                echo "background = #$bg"
            else
                echo "$line"
            fi
        done < "$CONFIG_PATH" > "$temp_file"

        cat "$temp_file" > "$CONFIG_PATH"
        rm "$temp_file"
        mkdir -p "$(dirname "$STATE_FILE")"
        echo "$theme" > "$STATE_FILE"
        # Update current terminal via OSC (other windows: Cmd+Shift+, to reload config)
        printf '\e]10;#%s\e\\\e]11;#%s\e\\' "$fg" "$bg"
        echo "Applied: $desc"
    }
    alias ct='changetheme'
fi

# try (run try.rb directly — gem wrapper breaks __FILE__ == $0 guard)
# macOS/Homebrew only; uses [ -f ] check which works in both bash and zsh
if [ -d /opt/homebrew/lib/ruby ]; then
    for _f in /opt/homebrew/lib/ruby/gems/*/gems/try-cli-*/try.rb; do
        [ -f "$_f" ] && eval "$(/opt/homebrew/opt/ruby/bin/ruby "$_f" init "$HOME/src/tries")" && break
    done
    unset _f
fi
